{
  "name": "lurker",
  "version": "1.0.0-beta",
  "description": "Self-hosted IRC client with persistent server-side connection and a Vue web UI",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/server.js",
    "server": "node server/server.js",
    "client:dev": "npm run dev --prefix vue_client",
    "client:build": "npm run build --prefix vue_client",
    "client:preview": "npm run preview --prefix vue_client",
    "install:all": "npm install && npm install --prefix vue_client",
    "start": "node server/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "irc",
    "self-hosted",
    "vue",
    "express"
  ],
  "license": "MPL-2.0",
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "archiver": "^8.0.0",
    "better-sqlite3": "^11.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "irc-framework": "^4.13.1",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
